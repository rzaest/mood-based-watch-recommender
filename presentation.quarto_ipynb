   "source": [
    "#| label: fig-prompt-results\n",
    "#| out-width: 100%\n",
    "#| fig-cap: Top five results returned for the prompt\n",
    "prompt_results = pd.Series({\n",
    "    \"Tenet\": 92.9,\n",
    "    \"Star Trek: Strange New Worlds\": 91.8,\n",
    "    \"Continuum\": 90.4,\n",
    "    \"X2: X-Men United²\": 89.3,\n",
    "    \"Inception\": 88.5,\n",
    "    \n",
    "}).sort_values()\n",
    "fig, ax = plt.subplots(figsize=(7.0, 4.1))\n",
    "bars = ax.barh(prompt_results.index, prompt_results.values, color=COLORS[\"teal\"])\n",
    "ax.bar_label(bars, labels=[f\"{v:.1f}%\" for v in prompt_results.values], padding=7, color=COLORS[\"ink\"], fontweight=\"bold\")\n",
    "ax.set_xlim(0, 100)\n",
    "ax.set_xticks([])\n",
    "ax.spines[[\"top\", \"right\", \"bottom\", \"left\"]].set_visible(False)\n",
    "ax.tick_params(axis=\"y\", labelsize=10, length=0)\n",
    "fig.patch.set_alpha(0)\n",
    "plt.tight_layout()"
   ]
